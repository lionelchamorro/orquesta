{
  "name": "orquesta",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/daemon/index.ts",
    "dev:all": "bash scripts/dev.sh",
    "ui": "bunx vite",
    "cli": "bun run src/cli/orq.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build:daemon": "bun build src/daemon/index.ts --target bun --outdir dist/daemon",
    "build:ui": "bunx vite build --outDir ../../dist/ui --emptyOutDir",
    "postbuild:ui": "cp src/ui/theme.css dist/ui/theme.css",
    "serve:ui": "bun run src/ui-server/index.ts",
    "dev:separate": "ORQ_CORS_ORIGIN=http://localhost:4173 bun run dev & VITE_DAEMON_URL=http://localhost:8000 bun run src/ui-server/index.ts",
    "build:tui": "cd tui && go build -o ../dist/orq-tui .",
    "tui": "dist/orq-tui",
    "build": "bun run build:daemon && bun run build:ui",
    "check": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}
