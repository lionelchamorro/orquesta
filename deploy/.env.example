# Copy to deploy/.env and fill in. docker compose auto-loads this file.

# Host port the external proxy targets (container always serves on 3000).
WEB_PORT=3000

# GitHub token so the api can clone PRIVATE repos over HTTPS.
# Create one at https://github.com/settings/tokens (scope: repo / read-only
# contents). Leave blank if you only register public repos.
GITHUB_TOKEN=
# GH_TOKEN=
