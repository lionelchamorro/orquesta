# Copy to deploy/.env and fill in. docker compose auto-loads this file.

# Host port the external proxy targets (container always serves on 3000).
WEB_PORT=3000

# Shared bearer token for the frontend/API proxy and MCP bridge when calling
# the loopback control-plane API. Set a real random value before deploying.
AUTH_TOKEN=

# GitHub token so the api can clone PRIVATE repos over HTTPS.
# Create one at https://github.com/settings/tokens (scope: repo / read-only
# contents). Leave blank if you only register public repos.
GITHUB_TOKEN=
# GH_TOKEN=

# Anthropic API key for the built-in chat (main's chat service uses the Anthropic
# SDK — a real API key, NOT the Claude subscription/OAuth in ~/.claude). Get one
# at https://console.anthropic.com/. Leave blank to disable chat.
ANTHROPIC_API_KEY=
