# Build-context excludes shared by all Dockerfiles in this repo.
# Keep Go sources (cmd/, internal/, go.mod), the Next app (app/, components/,
# lib/, public/, *.config.*), and the Python api (orquesta_api/, pyproject.toml,
# uv.lock) — everything below is either rebuilt inside the image or irrelevant.
.git
node_modules
.next
.venv
__pycache__
**/__pycache__
*.pyc
orquesta-frontend.zip
orquesta_api.db
workspaces/
.orquestalite/
.agents/
.claude/
docs/
tasks/
